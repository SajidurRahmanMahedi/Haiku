// Variables and data types in Haiku

let message = "Hello"
let count = 42
let price = 19.99
let active = true
let empty = none

// Using f-strings for cleaner output
println(f"String: {message}")
println(f"Integer: {count}")
println(f"Float: {price}")
println(f"Boolean: {active}")
println(f"None: {empty}")

// Type checking
println(f"Type of count: {type(count)}")
println(f"Type of message: {type(message)}")

// Constants
const PI = 3.14159
println(f"PI = {PI}")
