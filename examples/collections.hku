// Lists and Maps in Haiku

let fruits = ["apple", "banana", "cherry"]
let numbers = [1, 2, 3, 4, 5]

println(f"Fruits: {fruits}")
println(f"Length: {fruits.len()}")

fruits.push("date")
println(f"After push: {fruits}")

let first = fruits.get(0)
println(f"First fruit: {first}")

// List methods
let doubled = numbers.map((x) => x * 2)
println(f"Doubled: {doubled}")

let evens = numbers.filter((x) => x % 2 == 0)
println(f"Evens: {evens}")

let sum = numbers.reduce((acc, x) => acc + x, 0)
println(f"Sum: {sum}")

// Maps
let scores = {
    "alice": 95,
    "bob": 87,
    "charlie": 92
}

println(f"Scores: {scores}")
println(f"Alice's score: {scores["alice"]}")
println(f"Keys: {scores.keys()}")
println(f"Values: {scores.values()}")
